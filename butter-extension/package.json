{
  "name": "butter-extension",
  "displayName": "Butter Configuration Language Support",
  "description": "Syntax structural highlighting and auto-indent configuration mapping engines designed natively for the Butter DSL file ecosystem.",
  "version": "1.6.0",
  "publisher": "butter-io",
  "icon": "butter-logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:butter"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "butter.lint",
        "title": "Butter: Lint current file"
      },
      {
        "command": "butter.fmt",
        "title": "Butter: Format current file"
      }
    ],
    "configuration": {
      "title": "Butter",
      "properties": {
        "butter.compilerPath": {
          "type": "string",
          "default": "butter",
          "description": "Path to the butter compiler binary"
        }
      }
    },
    "languages": [{
      "id": "butter",
      "aliases": ["Butter", "butter"],
      "extensions": [".butter"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "icon.svg",
        "dark": "icon.svg"
      }
    }],
    "grammars": [{
      "language": "butter",
      "scopeName": "source.butter",
      "path": "./syntaxes/butter.tmLanguage.json"
    }]
  }
}
