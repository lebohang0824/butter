{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"]
  ],
  "autoClosingPairs": [
    {"open": "\"", "close": "\""},
    {"open": "[", "close": "]"}
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(feature|endpoint|listener|params|actions|responses|returns|param\\s+\\w+|response\\s+\\w+|field\\s+\\w+)\\b.*$",
    "decreaseIndentPattern": "^\\s*$"
  }
}
