# Butter Documentation System
product Docs
description "The official documentation site and demo applications for the Butter specification language — a language designed to communicate intent to AI agents by compiling structured specs that produce up to 100% expected results in a single shot."
version "1.11.0"

feature DocumentationSite
  description "The primary documentation website — a single-page HTML reference with syntax-highlighted code examples."
  version "1.11.0"

  params
    param Theme
      type enum["light", "dark"]
      default "light"
    param SidebarVisible
      type bool
      default true

  actions
    action "Render hero section with Butter tagline and quick-start code snippet"
    action "Display Design Philosophy section explaining Butter's AI intent workflow: write spec, compile to JSON, feed to AI agent, get up to 100% alignment in one shot"
    action "Show installation instructions for Linux, macOS, and Windows via install scripts"
    action "Render Getting Started guide with a hello world example and compile workflow"
    action "Render Language Guide with tables for keywords, parameter fields, types, and conditionals"
    action "Render AI Workflow section explaining the write-compile-feed workflow"
    action "Link to CLI Reference page with compile, fmt commands, flags, and error reference"
    action "Link to VS Code Extension page with installation and feature list"
    action "Render changelog and version history"

feature SyntaxHighlighter
  description "Custom Prism.js-based syntax highlighting for the Butter language in code blocks."
  version "1.0.0"

  params
    param LanguageID
      type string
      default "butter"
    param ThemeScope
      type string
      default "source.butter"

  actions
    action "Tokenize Butter keywords: app, product, description, version, feature, params, param, actions, action"
    action "Tokenize type keywords: string, int, float, bool, enum"
    action "Tokenize parameter field keywords: type, required, default, validate, length"
    action "Tokenize conditionals: if, unless, when, while"
    action "Tokenize comment lines starting with #"
    action "Tokenize double-quoted string literals"
    action "Tokenize pipe operators for action conditions"

feature TodoDemoApp
  description "A working single-page todo application. An AI agent generated this entire app from the todo.butter spec in a single shot — demonstrating Butter's philosophy: write spec, compile to JSON, feed to AI, get up to 100% alignment."
  version "1.0.0"

  params
    param TaskTitle
      type string
      required true
    param Priority
      type enum["low", "medium", "high", "urgent"]
      default "medium"
    param StatusFilter
      type enum["all", "pending", "completed", "archived"]
      default "all"

  actions
    action "Render tabbed interface with feature panels: CreateTask, ListTasks, UpdateTask, DeleteTask"
    action "Populate CreateTask form with Title, Description, Priority, DueDate fields"
    action "Execute validation: title required, priority defaults to medium"
    action "Assign unique identifier and creation timestamp on task creation"
    action "Render ListTasks panel with filter and sort controls"
    action "Query and display task list with status badges and Edit buttons"
    action "Open update modal with pre-filled fields from existing task"
    action "Apply status changes and update modification timestamp"
    action "Open delete confirmation modal with TaskID lookup and title verification"
    action "Broadcast task lifecycle events to connected clients"
    action "Execute sequential action steps with visual step-log showing pending, running, done, skip, and error states"
    action "Evaluate semantic conditions: skip actions when conditions are not met, mark them with skip indicator"

